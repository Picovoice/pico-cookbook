<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speaker Aware Wake Word"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/brand_primary"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to Enroll"
        android:textSize="18sp"
        android:textAlignment="center"/>

    <LinearLayout
        android:id="@+id/layoutEnroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enrolled Profiles"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp"
            android:textStyle="bold"
            android:textAllCaps="true"/>

        <ai.picovoice.speakerawarewakeword.FlowLayout
            android:id="@+id/speakerChipContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/btnAddSpeaker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"
                android:background="@drawable/add_speaker_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </ai.picovoice.speakerawarewakeword.FlowLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/greeting_container_bg"
        android:elevation="6dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/greetingPrefixText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello "
            android:textSize="40sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/greetingSpeakerNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/speaker_pill_bg"
            android:textColor="@color/white"
            android:textSize="40sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Speaker 1"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/enrollProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:progressDrawable="@drawable/circular_progress"
        android:progress="0"
        android:max="100"
        android:visibility="gone"
        android:layout_marginTop="24dp"/>

    <ai.picovoice.speakerawarewakeword.VolumeMeterView
        android:id="@+id/volumeMeterView"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="32dp">

        <Button
            android:id="@+id/btnStartEnroll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Enrollment"
            android:backgroundTint="@color/brand_primary"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnClearAll"
            android:backgroundTint="@color/gray_light"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear Profiles"
            android:textColor="#333333"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnStartTest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Testing"
            android:backgroundTint="@color/brand_primary"
            android:textColor="@color/white"
            android:visibility="gone"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:backgroundTint="@color/gray_light"
        android:textColor="#333333"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

</LinearLayout>